{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".github/**",
      "README.md",
      "GUIA-NUEVO-PROYECTO.md",
      ".gitignore",
      "node_modules/**",
      ".git/**"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "max-age=300" }
        ]
      }
    ]
  }
}
